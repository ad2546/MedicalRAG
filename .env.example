# ─── Database ─────────────────────────────────────────────────────────────────
# In docker-compose.prod.yml the host is "postgres" (service name)
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME@postgres:5432/medicalrag
DATABASE_URL_SYNC=postgresql://postgres:CHANGE_ME@postgres:5432/medicalrag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME          # choose a strong password
POSTGRES_DB=medicalrag

# ─── OCI Generative AI ────────────────────────────────────────────────────────
# Option A — API Key (local dev / no Instance Principal)
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-ocid
OCI_REGION=us-ashburn-1
OCI_CONFIG_PROFILE=DEFAULT
OCI_MODEL_GEN=meta.llama-3.3-70b-instruct
OCI_MODEL_CHAT=meta.llama-3.3-70b-instruct

# Option B — Instance Principal (recommended for OCI Compute VMs, no key needed)
# OCI_USE_INSTANCE_PRINCIPAL=true
# Leave OCI_CONFIG_PROFILE blank when using Instance Principal

# ─── Okahu Cloud (monocle-apptrace observability) ─────────────────────────────
OKAHU_API_KEY=okh_your-okahu-api-key-here
# Must match the App ID shown in your Okahu Cloud portal
OKAHU_SERVICE_NAME=medicalchatbot_ni9wbg

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=384

# ─── Retrieval ────────────────────────────────────────────────────────────────
TOP_K_DOCS=5
REFLECTION_CONFIDENCE_THRESHOLD=0.5
MAX_REFLECTION_ROUNDS=1

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random value: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=CHANGE_ME
AUTH_TOKEN_EXP_MINUTES=1440         # 24 h
AUTH_COOKIE_NAME=access_token
DEFAULT_USER_REQUEST_LIMIT=5

# ─── Workflow endpoint (for Okahu Cloud / n8n / external triggers) ────────────
# Generate a random string: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WORKFLOW_API_KEY=CHANGE_ME

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
