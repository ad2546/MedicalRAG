# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medicalrag
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/medicalrag

# OCI Generative AI
# Get these from OCI Console → Identity → Users → API Keys
OCI_TENANCY_OCID=ocid1.tenancy.oc1..your-tenancy-ocid
OCI_USER_OCID=ocid1.user.oc1..your-user-ocid
OCI_FINGERPRINT=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
OCI_PRIVATE_KEY_FILE=~/.oci/oci_api_key.pem
# OCI_PRIVATE_KEY_CONTENT=  # alternative: inline PEM string (useful in containers)
OCI_REGION=us-chicago-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-ocid
OCI_MODEL_ID=meta.llama-3.3-70b-instruct
# Set to true on OCI compute instances to use Instance Principal auth (no keys needed)
OCI_USE_INSTANCE_PRINCIPAL=false

# Okuha Cloud
OKUHA_API_KEY=okh_your-okahu-key-here
OKUHA_SERVICE_NAME=medical-rag

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# Retrieval
TOP_K_DOCS=5
REFLECTION_CONFIDENCE_THRESHOLD=0.5
MAX_REFLECTION_ROUNDS=2

# App
APP_ENV=development
LOG_LEVEL=INFO
