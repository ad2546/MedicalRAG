## Required ────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxx
GROQ_API_KEY=gsk_xxx
OKAHU_API_KEY=okh_xxx

## n8n owner account (created on first run)
N8N_OWNER_EMAIL=admin@example.com
N8N_OWNER_PASSWORD=ChangeMe123!
N8N_OWNER_FIRSTNAME=Admin
N8N_OWNER_LASTNAME=User

## Postgres
PG_PASSWORD=password

## n8n public URL (set to EC2 public DNS once known)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
